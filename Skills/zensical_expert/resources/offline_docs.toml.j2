[project]
site_name = "{{ site_name | default('My Offline Docs') }}"
# Do NOT set site_url for offline builds

[project.theme]
variant  = "modern"
features = [
    "search.suggest",
    "content.code.copy",
    # Do NOT use navigation.instant (requires site_url)
]

[project.markdown_extensions.admonition]
[project.markdown_extensions.pymdownx.details]
[project.markdown_extensions.pymdownx.superfences]
[project.markdown_extensions.pymdownx.highlight]
  anchor_linenums = true
[project.markdown_extensions.tables]
[project.markdown_extensions.toc]
  permalink = true

[project.plugins.search]
[project.plugins.offline]
  enabled = true
# offline plugin automatically sets use_directory_urls = false
